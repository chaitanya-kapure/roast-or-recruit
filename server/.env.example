# Get a free API key from https://aistudio.google.com/apikey
# Gemini keys always start with "AIza"
GEMINI_API_KEY=your_gemini_api_key_here
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/roast-or-recruit
JWT_SECRET=change-this-to-a-random-secret
# Comma-separated allowed CORS origins (default: localhost:5173)
CORS_ORIGIN=https://yourdomain.com

# --- Email delivery (fallback chain: Gmail API → Resend → SMTP → console) ---
#
# Gmail API (primary — always works over HTTPS)
# Generate via: node scripts/get-gmail-token.js
# Requires Google Cloud OAuth2 credentials (see README)
GMAIL_USER=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
#
# Resend API (fallback — free at resend.com)
RESEND_API_KEY=
